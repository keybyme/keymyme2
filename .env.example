# Copiar este archivo a .env y completar los valores.
# .env NUNCA debe subirse al repositorio (ya está en .gitignore).

# Django
SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Requerida en producción (detrás de un load balancer con TLS, ej. DigitalOcean App Platform)
CSRF_TRUSTED_ORIGINS=

# Base de datos PostgreSQL (no hay fallback a SQLite)
DATABASE_URL=postgres://usuario:password@localhost:5432/keybyme

# Llave de cifrado para los passwords guardados en el vault (VaultPassword).
# Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# IMPORTANTE: si se pierde esta llave, todos los passwords guardados quedan
# permanentemente irrecuperables. Nunca la regeneres en un ambiente con datos reales.
VAULT_ENCRYPTION_KEY=change-me

# Correo saliente para los avisos de Recordatorios (python manage.py send_due_reminders).
# En DEBUG=True no es necesario configurarlo: los correos se imprimen en la consola.
# Ejemplo con Gmail: EMAIL_HOST=smtp.gmail.com, EMAIL_PORT=587, EMAIL_HOST_USER=tu_cuenta@gmail.com,
# EMAIL_HOST_PASSWORD=<contraseña de aplicación, no la normal>
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=KeyByMe <no-reply@keybyme.com>

# DigitalOcean Spaces (solo si USE_SPACES=True)
USE_SPACES=False
SPACES_ACCESS_KEY_ID=
SPACES_SECRET_ACCESS_KEY=
SPACES_BUCKET_NAME=
SPACES_ENDPOINT_URL=
SPACES_REGION=nyc3
